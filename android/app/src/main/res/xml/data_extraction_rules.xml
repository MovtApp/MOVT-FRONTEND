<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+): bloqueia a extração de dados do app tanto para backup
  em nuvem quanto para transferência device-to-device. Combinado com
  android:allowBackup="false", impede que tokens/sessão guardados localmente
  sejam extraídos via 'adb backup' ou migração de aparelho.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
