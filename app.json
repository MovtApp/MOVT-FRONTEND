{
  "expo": {
    "name": "MOVT",
    "slug": "movt",
    "scheme": "movt",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./src/assets/iconBuild.png",
    "splash": {
      "image": "./src/assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.dsvmTechnology.movtapp",
      "supportsTablet": false,
      "infoPlist": {
        "UIBackgroundModes": [
          "background-fetch",
          "background-processing",
          "location",
          "bluetooth-central"
        ],
        "NSLocationWhenInUseUsageDescription": "Este aplicativo precisa de acesso à sua localização para mostrar você no mapa e rastrear atividades de ciclismo.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Este aplicativo precisa de acesso à localização em segundo plano para rastrear suas rotas de exercício.",
        "NSHealthShareUsageDescription": "Este aplicativo precisa de acesso aos seus dados de saúde para mostrar seu progresso fitness.",
        "NSHealthUpdateUsageDescription": "Este aplicativo precisa registrar seus dados de saúde para rastrear suas atividades.",
        "NSBluetoothAlwaysUsageDescription": "Este aplicativo usa Bluetooth para conectar e sincronizar dados com seu relógio inteligente.",
        "NSBluetoothPeripheralUsageDescription": "Este aplicativo usa Bluetooth para descobrir e parear com dispositivos de monitoramento de saúde."
      }
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDTRVXtY25ARGfBPaFIqva84QeAgziJ9Ds"
        }
      },
      "package": "com.dsvmTechnology.movtapp",
      "versionCode": 21,
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.BODY_SENSORS",
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_TOTAL_CALORIES_BURNED",
        "android.permission.health.READ_OXYGEN_SATURATION",
        "android.permission.health.READ_SLEEP_SESSION",
        "android.permission.health.WRITE_STEPS",
        "android.permission.health.WRITE_HEART_RATE",
        "android.permission.health.WRITE_TOTAL_CALORIES_BURNED",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"
      ]
    },
    "runtimeVersion": "1.0.0",
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-web-browser",
      "expo-sensors",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": ["peripheral", "central"],
          "bluetoothAlwaysPermission": "Este aplicativo usa Bluetooth para conectar e sincronizar dados com seu relógio inteligente."
        }
      ],
      "./plugins/withNdkVersion.js",
      "./plugins/withHealthConnectManifest.js",
      "react-native-health-connect",
      "react-native-health",
      [
        "@sentry/react-native/expo",
        {
          "organization": "movt-app-pw",
          "project": "react-native"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6edbc095-2229-4734-8443-27ec0ca14ee1",
        "versionSource": "local"
      }
    },
    "updates": {},
    "owner": "jvlima22"
  }
}
